# ─────────────────────────────────────────────────────────────────────────────
# Production environment — copy to .env.production and fill in real values.
# Never commit .env.production to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=plm_project
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=change-me-at-least-32-random-chars
JWT_EXPIRES_IN=8h

# ── App port (host port for the nginx frontend container) ────────────────────
APP_PORT=80
